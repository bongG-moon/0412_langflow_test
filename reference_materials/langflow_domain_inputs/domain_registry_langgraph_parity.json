  "entries": [
    {
      "id": "custom_wip_hold_anomaly",
      "title": "WIP HOLD 이상여부 정의",
      "created_at": "2026-04-15T00:00:00",
      "raw_text": "HOLD 이상여부는 wip 상태가 HOLD, REWORK면 이상이고 아니면 정상이다.",
      "dataset_keywords": [
        {
          "dataset_key": "wip",
          "keywords": [
            "재공이상",
            "재공 이상",
            "홀드 체크"
          ]
        }
      ],
      "value_groups": [],
      "analysis_rules": [
        {
          "name": "hold_anomaly_check",
          "display_name": "HOLD 이상여부",
          "synonyms": [
            "hold_anomaly_check",
            "HOLD 이상여부",
            "홀드 체크",
            "재공 이상여부"
          ],
          "required_datasets": [
            "wip"
          ],
          "required_columns": [
            "상태"
          ],
          "source_columns": [
            {
              "dataset_key": "wip",
              "column": "상태",
              "role": "status_field"
            }
          ],
          "calculation_mode": "condition_flag",
          "output_column": "hold_anomaly_flag",
          "default_group_by": [],
          "condition": "상태 in ['HOLD', 'REWORK']",
          "decision_rule": "상태가 HOLD 또는 REWORK이면 '이상', 그 외는 '정상'",
          "formula": "",
          "pandas_hint": "df['hold_anomaly_flag'] = df['상태'].apply(lambda x: '이상' if x in ['HOLD', 'REWORK'] else '정상')",
          "description": "WIP 상태 컬럼이 HOLD 또는 REWORK인 경우를 이상으로 분류하는 규칙",
          "source": "custom"
        }
      ],
      "join_rules": [],
      "notes": [
        "WIP 상태가 HOLD 또는 REWORK이면 이상으로 판정한다."
      ]
    },
    {
      "id": "custom_plan_gap_rate",
      "title": "생산 목표 차이율 정의",
      "created_at": "2026-04-15T00:00:00",
      "raw_text": "생산 목표 차이율은 (production - target) / target로 계산한다.",
      "dataset_keywords": [],
      "value_groups": [],
      "analysis_rules": [
        {
          "name": "plan_gap_rate",
          "display_name": "생산 목표 차이율",
          "synonyms": [
            "plan_gap_rate",
            "생산 목표 차이율",
            "목표 차이율",
            "계획 차이율"
          ],
          "required_datasets": [
            "production",
            "target"
          ],
          "required_columns": [
            "production",
            "target"
          ],
          "source_columns": [
            {
              "dataset_key": "production",
              "column": "production",
              "role": "production_value"
            },
            {
              "dataset_key": "target",
              "column": "target",
              "role": "target_value"
            }
          ],
          "calculation_mode": "custom",
          "output_column": "plan_gap_rate",
          "default_group_by": [
            "OPER_NAME"
          ],
          "condition": "",
          "decision_rule": "",
          "formula": "(production - target) / target",
          "pandas_hint": "Merge production and target datasets on common keys, then calculate (production - target) / target grouped by OPER_NAME",
          "description": "생산량과 목표량의 차이를 목표량 대비 비율로 산출하는 지표",
          "source": "custom"
        }
      ],
      "join_rules": [
        {
          "name": "plan_gap_rate_join",
          "base_dataset": "production",
          "join_dataset": "target",
          "join_type": "left",
          "join_keys": [
            "WORK_DT",
            "OPER_NAME",
            "MODE",
            "DEN"
          ],
          "description": "생산 목표 차이율 계산을 위한 production-target 결합 규칙",
          "source": "custom"
        }
      ],
      "notes": [
        "계산식은 (production - target) / target이다.",
        "기본 집계 단위는 공정(OPER_NAME)이다."
      ]
    },
