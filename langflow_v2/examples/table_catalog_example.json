{
  "catalog_id": "manufacturing_v2_example",
  "description": "Metadata-only dataset catalog for Langflow v2. SQL belongs inside retriever component functions.",
  "datasets": {
    "production": {
      "display_name": "Production",
      "description": "Daily production quantity by date, process, line, and product.",
      "keywords": ["production", "output", "actual", "실적", "생산"],
      "question_examples": ["오늘 D/A3 생산 보여줘", "20260422 DDR5 생산 실적"],
      "tool_name": "get_production_data",
      "db_key": "PKG_RPT",
      "required_params": ["date"],
      "grain": ["WORK_DT", "OPER_NAME", "MODE", "DEN", "TECH"],
      "primary_quantity_column": "production",
      "columns": [
        {"name": "WORK_DT", "type": "date", "description": "Work date"},
        {"name": "OPER_NAME", "type": "string", "description": "Process name"},
        {"name": "MODE", "type": "string", "description": "Product mode"},
        {"name": "LINE", "type": "string", "description": "Line"},
        {"name": "DEN", "type": "string", "description": "Density"},
        {"name": "TECH", "type": "string", "description": "Technology"},
        {"name": "MCP_NO", "type": "string", "description": "MCP product code"},
        {"name": "PKG_TYPE1", "type": "string", "description": "Package type"},
        {"name": "production", "type": "number", "description": "Production quantity"}
      ],
      "filter_mappings": {
        "process_name": ["OPER_NAME"],
        "mode": ["MODE"],
        "line": ["LINE"],
        "den": ["DEN"],
        "tech": ["TECH"],
        "mcp_no": ["MCP_NO"],
        "product_name": ["MCP_NO", "MODE", "DEN", "TECH", "PKG_TYPE1"]
      }
    },
    "target": {
      "display_name": "Production Target",
      "description": "Daily production target by date, process, line, and product.",
      "keywords": ["target", "plan", "goal", "목표", "계획"],
      "question_examples": ["오늘 생산 목표 대비 달성률 보여줘"],
      "tool_name": "get_target_data",
      "db_key": "PKG_RPT",
      "required_params": ["date"],
      "grain": ["WORK_DT", "OPER_NAME", "MODE", "DEN", "TECH"],
      "primary_quantity_column": "target",
      "columns": [
        {"name": "WORK_DT", "type": "date"},
        {"name": "OPER_NAME", "type": "string"},
        {"name": "MODE", "type": "string"},
        {"name": "LINE", "type": "string"},
        {"name": "DEN", "type": "string"},
        {"name": "TECH", "type": "string"},
        {"name": "MCP_NO", "type": "string"},
        {"name": "target", "type": "number"}
      ],
      "filter_mappings": {
        "process_name": ["OPER_NAME"],
        "mode": ["MODE"],
        "line": ["LINE"],
        "den": ["DEN"],
        "tech": ["TECH"],
        "mcp_no": ["MCP_NO"],
        "product_name": ["MCP_NO", "MODE", "DEN", "TECH"]
      }
    }
  }
}
