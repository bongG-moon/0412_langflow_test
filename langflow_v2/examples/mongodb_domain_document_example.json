{
  "domain_id": "manufacturing_default",
  "status": "active",
  "metadata": {
    "version": "v2",
    "owner": "manufacturing-agent",
    "description": "Aggregate domain document alternative to gbn/key/payload item documents."
  },
  "domain": {
    "products": {},
    "process_groups": {
      "DA": {
        "display_name": "Die Attach",
        "aliases": ["DA", "D/A", "DA공정"],
        "processes": ["D/A1", "D/A2", "D/A3"]
      },
      "WB": {
        "display_name": "Wire Bond",
        "aliases": ["WB", "W/B", "WB공정"],
        "processes": ["W/B1", "W/B2"]
      }
    },
    "terms": {},
    "datasets": {
      "production": {
        "aliases": ["생산", "실적", "production"]
      },
      "target": {
        "aliases": ["목표", "계획", "target"]
      }
    },
    "metrics": {
      "achievement_rate": {
        "display_name": "Achievement Rate",
        "aliases": ["달성률", "달성율", "목표 대비", "achievement", "achievement rate"],
        "required_datasets": ["production", "target"],
        "formula": "sum(production) / sum(target) * 100",
        "output_column": "achievement_rate",
        "source_columns": ["production", "target"],
        "grouping_hint": ["MODE", "OPER_NAME"]
      }
    },
    "join_rules": [
      {
        "name": "production_target_daily_join",
        "left_dataset": "production",
        "right_dataset": "target",
        "keys": ["WORK_DT", "OPER_NAME", "OPER_NUM", "MODE", "DEN", "TECH", "MCP_NO"],
        "join_type": "inner"
      }
    ]
  }
}
